<winuiex:WindowEx
    x:Class="Natsurainko.FluentLauncher.Views.QuickLookWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:winuiex="using:WinUIEx"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar row -->
        <Grid
            x:Name="TitleBarRoot"
            Grid.Row="0"
            Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel
                Grid.Column="0"
                Margin="6,0,0,0"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="6">
                <Button
                    x:Name="BackButton"
                    Width="32"
                    Height="32"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="Back_Click"
                    CornerRadius="8">
                    <FontIcon
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        FontSize="14"
                        Glyph="&#xE72B;" />
                </Button>

                <ToggleButton
                    x:Name="TopMostToggle"
                    Width="32"
                    Height="32"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    Checked="TopMostToggle_Checked"
                    Unchecked="TopMostToggle_Unchecked"
                    CornerRadius="8">
                    <FontIcon
                        x:Name="TopMostIcon"
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        FontSize="14"
                        Glyph="&#xE718;" />
                </ToggleButton>

                <TextBlock
                    Margin="6,0,0,0"
                    VerticalAlignment="Center"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Text="QuickLook" />
            </StackPanel>

            <!-- Keep some right padding so we don't collide with system caption buttons -->
            <DropDownButton
                Grid.Column="2"
                Margin="0,6,140,6"
                Padding="10,6"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Background="{ThemeResource ButtonBackground}"
                BorderBrush="{ThemeResource ButtonBorderBrush}"
                BorderThickness="{ThemeResource ButtonBorderThemeThickness}"
                CornerRadius="8">
                <TextBlock Text="{x:Bind CurrentSiteName, Mode=OneWay}" />
                <DropDownButton.Flyout>
                    <MenuFlyout Placement="BottomEdgeAlignedRight">
                        <MenuFlyoutItem Text="Minecraft Wiki" Click="MinecraftWiki_Click" />
                        <MenuFlyoutItem Text="MOD百科" Click="McMod_Click" />
                    </MenuFlyout>
                </DropDownButton.Flyout>
            </DropDownButton>
        </Grid>

        <WebView2
            x:Name="WebView"
            Grid.Row="1"
            Source="https://zh.minecraft.wiki/"
            Loaded="WebView_Loaded" />
    </Grid>
</winuiex:WindowEx>
